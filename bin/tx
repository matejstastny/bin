#!/usr/bin/env bash

# tmux layout loader

# -------- layouts --------
# format: name|layout|directory
layouts=(
    "Gazebo Sim|5dda,181x43,0,0{110x43,0,0,2,70x43,111,0[70x11,111,0,3,70x31,111,12,4]}|$HOME/devel/gazebo-simulations"
    "Flaggi|2cdb,181x43,0,0{106x43,0,0,13,74x43,107,0[74x17,107,0,14,74x25,107,18,15]}|$HOME/devel/flaggi"
)

# -------- picker --------
choice=$(printf "%s\n" "${layouts[@]}" | cut -d'|' -f1 | fzf --prompt="layout > ")
[ -z "$choice" ] && exit 0

# -------- find selected entry --------
for entry in "${layouts[@]}"; do
    name="${entry%%|*}"
    if [[ "$name" == "$choice" ]]; then
        layout=$(echo "$entry" | cut -d'|' -f2)
        dir=$(echo "$entry" | cut -d'|' -f3)
        break
    fi
done

# fallback directory
[ -z "$dir" ] && dir="$PWD"

# -------- ensure panes exist (3 default) --------
panes=$(tmux list-panes | wc -l)
while [ "$panes" -lt 3 ]; do
    tmux split-window -c "$dir"
    panes=$((panes + 1))
done

# -------- set pane dirs --------
# set all panes to directory
for pane in $(tmux list-panes -F "#{pane_id}"); do
    tmux send-keys -t "$pane" "cd \"$dir\" && clear" C-m
done

# -------- apply layout --------
tmux select-layout "$layout"
